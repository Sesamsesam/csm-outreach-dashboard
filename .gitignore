# Personal data — never commit
csm_jobs.csv
seen_job_ids.txt
user_profile.txt

# Live search targeting (the user's current knob settings). Gitignored so personal
# targeting never ships; a fresh clone falls back to search_config.example.json (CSM).
search_config.json
cover_letters/*.txt
cover_letters/*.md

# Per-machine setup marker - written after a successful local setup so a second
# tool (e.g. Cowork) opening the same folder skips setup instead of re-running it.
# Must stay gitignored: a fresh clone should NOT inherit an "already set up" flag.
setup_complete.json

# API keys
dashboard/.hunter_key
dashboard/.apollo_key

# Python
__pycache__/
*.pyc
*.pyo

# macOS
.DS_Store

# Stray skill bundles (the .claude/skills/ folders are the source of truth;
# this project does not use .skill bundles)
*.skill

# Temp / unknown files
ziD6IQFX

# Claude personal settings (keep launch.json but not local permissions)
.claude/settings.local.json
